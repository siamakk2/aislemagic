{
  "version": 2,
  "buildCommand": "echo 'Static site - no build needed'",
  "outputDirectory": ".",
  "routes": [
    { "handle": "filesystem" },
    { "src": "/app", "dest": "/app/index.html" },
    { "src": "/app/(.*)", "dest": "/app/index.html" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
